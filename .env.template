# Environment Variables Template
# Copy this to .env and fill in your actual values

# KV Namespace IDs (get these from wrangler kv namespace create commands)
KV_NAMESPACE_ID=your-production-namespace-id-here
KV_NAMESPACE_PREVIEW_ID=your-preview-namespace-id-here

# Discord Configuration (get these from Discord Developer Portal)
DISCORD_APPLICATION_ID=your-discord-application-id-here
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Note: DISCORD_PUBLIC_KEY should be set as a Cloudflare Worker secret:
# wrangler secret put DISCORD_PUBLIC_KEY
