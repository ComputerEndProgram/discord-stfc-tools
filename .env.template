# Environment Variables Template
# Copy this to .env and fill in your actual values

# D1 database (create with: wrangler d1 create stfc-db)
D1_DATABASE_NAME=stfc-db
D1_DATABASE_ID=your-d1-database-id-here

# KV Namespace IDs (optional — coordinate lookup uses bundled systemData.ts)
KV_NAMESPACE_ID=your-production-namespace-id-here
KV_NAMESPACE_PREVIEW_ID=your-preview-namespace-id-here

# Discord Configuration (Discord Developer Portal)
DISCORD_APPLICATION_ID=your-discord-application-id-here
DISCORD_PUBLIC_KEY=your-discord-public-key-here
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Public URL of the deployed worker
WORKER_URL=https://stfc-tools.your-subdomain.workers.dev

# R2 bucket for archived verification screenshots (optional)
R2_BUCKET_NAME=stfc-verification-assets

# Push .env to Cloudflare (secrets + regenerate wrangler.json):
#   npm run push-env
#
# Or set secrets manually:
#   npx wrangler secret put DISCORD_PUBLIC_KEY
#   npx wrangler secret put DISCORD_BOT_TOKEN
#
# Enable privileged intents in Discord Developer Portal:
#   - Server Members Intent (GUILD_MEMBER_ADD + member poll fallback)
#   - Message Content Intent (read verification DMs via Gateway)
#
# Gateway runs in a Durable Object (DISCORD_GATEWAY binding) — deploy applies migration v1 automatically.
